rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isStaff() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/user_roles/$(request.auth.uid));
    }
    
    function isAdmin() {
      return isStaff() && 
             get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // User Profiles (Staff only)
    match /profiles/{userId} {
      allow read: if isStaff();
      allow write: if isAdmin() || isOwner(userId);
    }
    
    // User Roles (Admin only for write, staff for read)
    match /user_roles/{userId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }
    
    // Customers
    match /customers/{customerId} {
      // Customers can read/write their own data
      allow read, write: if isOwner(customerId);
      // Staff can read all customers
      allow read: if isStaff();
      
      // Customer addresses (subcollection)
      match /addresses/{addressId} {
        allow read, write: if isOwner(customerId);
        allow read: if isStaff();
      }
    }
    
    // Menu Items
    match /menu_items/{itemId} {
      // Anyone can read menu items (public)
      allow read: if true;
      // Only staff can modify menu
      allow write: if isStaff();
    }
    
    // Orders
    match /orders/{orderId} {
      // Customers can read their own orders
      allow read: if isAuthenticated() && 
                     resource.data.customer_id == request.auth.uid;
      // Staff can read all orders
      allow read: if isStaff();
      // Customers can create orders
      allow create: if isAuthenticated() && 
                       request.resource.data.customer_id == request.auth.uid;
      // Staff can create and update orders
      allow create, update: if isStaff();
      // Only admin can delete orders
      allow delete: if isAdmin();
      
      // Order items (subcollection)
      match /items/{itemId} {
        // Same permissions as parent order
        allow read: if isAuthenticated() && 
                       (get(/databases/$(database)/documents/orders/$(orderId)).data.customer_id == request.auth.uid ||
                        isStaff());
        allow write: if isStaff();
      }
    }
  }
}
